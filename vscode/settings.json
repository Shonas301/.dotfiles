{
  "telemetry.enableTelemetry": false,
  "extensions.autoUpdate": false,
  "liveshare.connectionMode": "relay",
  "liveshare.anonymousGuestApproval": "reject",
  "liveshare.allowedDomains": [],
  "vim.statusBarColors.replace": "",
  "vim.insertModeKeyBindings": [
    {
      "before": [";", ";"],
      "after": ["<Esc>"]
    },
    {
      "before": ["j", "j"],
      "after": ["<Esc>"]
    }
  ],
  "vim.useSystemClipboard": true,
  "vim.easymotion": true,
  "files.autoSave": "onFocusChange",
  "vim.textwidth": 80,
  "editor.formatOnSave": true,
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[python]": {
    "editor.formatOnSave": true
  },
  "python.formatting.blackPath": "black",
  "editor.fontSize": 10,
  "explorer.confirmDelete": false,
  "diffEditor.ignoreTrimWhitespace": false,
  "cmake.configureOnOpen": true,
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter.notebook.ipynb"
  },
  "python.formatting.provider": "black",
  "explorer.confirmDragAndDrop": false,
  "markdown.preview.fontSize": 10,
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "prettier.tabWidth": 2,
  "security.workspace.trust.untrustedFiles": "open",
  "window.nativeTabs": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "redhat.telemetry.enabled": false,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.sendKeybindingsToShell": true,
  "go.inferGopath": true,
  "sqltools.autoOpenSessionFiles": false,
  "sqltools.highlightQuery": false,
  "sqltools.showStatusbar": false,
  "window.restoreWindows": "one",
  "terminal.external.osxExec": "iTerm",
  "gitlens.remotes": [],
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "vim.camelCaseMotion.enable": true,
  "C_Cpp.formatting": "clangFormat",
  "clangd.detectExtensionConflicts": false,
  "vim.foldfix": true,
  "editor.minimap.renderCharacters": false,
  "editor.cursorBlinking": "solid",
  "workbench.editor.scrollToSwitchTabs": true,
  "editor.mouseWheelScrollSensitivity": 0.01,
  "terminal.integrated.mouseWheelScrollSensitivity": 5,
  "liveshare.languages.allowGuestCommandControl": true,
  "liveshare.presence": true,
  "liveshare.publishWorkspaceInfo": true,
  "liveshare.allowGuestDebugControl": true,
  "liveshare.allowGuestTaskControl": true,
  "liveshare.accessibility.accessibilityFeaturesEnabled": true,
  "liveshare.alwaysFollowHost": true,
  "yaml.validate": false,
  "telemetry.telemetryLevel": "off",
  "window.zoomLevel": -1,
  "workbench.activityBar.location": "hidden"
}
